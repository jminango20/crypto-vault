# .env.example
# Copy this file to .env and fill with your actual values
# DO NOT commit .env file!

# ========================================
# DATABASE
# ========================================
DATABASE_URL=jdbc:postgresql://localhost:5433/cryptovault
DATABASE_USER=cryptovault
DATABASE_PASSWORD=your_password_here
JPA_DDL_AUTO=update

# ========================================
# BLOCKCHAIN (KALEIDO)
# ========================================
BLOCKCHAIN_RPC_URL=https://username:password@your-kaleido-rpc-url/
BLOCKCHAIN_WS_URL=wss://username:password@your-kaleido-ws-url/
BLOCKCHAIN_CHAIN_ID=1203373641
BLOCKCHAIN_CONFIRMATIONS=2

# ========================================
# CRYPTOVAULT SECURITY
# ========================================
JWT_SECRET=your-jwt-secret-minimum-32-characters
JWT_EXPIRATION=86400000

MASTER_SEED=BASE64:your-base64-encoded-seed
MASTER_PASSWORD=your-master-password

ENCRYPTION_PASSWORD=your-encryption-password

# ========================================
# GAS CONFIGURATION
# ========================================
GAS_PRICE=0
GAS_LIMIT=6721975

# ========================================
# OTHER
# ========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
LOG_LEVEL=DEBUG