spring:
  application:
    name: CryptoVault

  profiles:
    active: ${SPRING_PROFILE:local}

  datasource:
    url: ${DATABASE_URL:jdbc:postgresql://localhost:5433/cryptovault}
    username: ${DATABASE_USER:cryptovault}
    password: ${DATABASE_PASSWORD:cryptovault123}
    hikari:
      maximum-pool-size: 10
      minimum-idle: 2

  jpa:
    hibernate:
      ddl-auto: validate
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true
    show-sql: false

  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration

  security:
    user:
      name: admin
      password: ${ADMIN_PASSWORD:admin123}

server:
  port: ${SERVER_PORT:8080}
  error:
    include-message: always
    include-stacktrace: on_param

cryptovault:
  version: 1.0.0
  security:
    enable-address-validation: true
    max-derivation-attempts: 10
    jwt:
      secret: ${JWT_SECRET:your-256-bit-secret-your-256-bit-secret}
      expiration: 86400000 # 24 hours
  master:
    seed: ${MASTER_SEED:development-seed-not-for-production}
    password: ${MASTER_PASSWORD:change-me-in-production}
  blockchain:
    rpc-url: ${BLOCKCHAIN_RPC:http://localhost:8545}
    chain-id: ${CHAIN_ID:1337}
    gas-price: 0
    gas-limit: 6000000

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: always

logging:
  level:
    com.jminango.cryptovault: DEBUG
    org.springframework.web: INFO
    org.hibernate: WARN